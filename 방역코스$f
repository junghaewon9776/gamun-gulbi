function moveVehicle(id, dir) {
  const data = loadData();
  const sorted = (data.vehicles || []).slice().sort((a, b) => (a.order || 9999) - (b.order || 9999));
  const idx = sorted.findIndex(v => v.id === id);
  if (idx < 0) return;
  const swapIdx = idx + dir;
  if (swapIdx < 0 || swapIdx >= sorted.length) return;
  const tmp = sorted[idx];
  sorted[idx] = sorted[swapIdx];
  sorted[swapIdx] = tmp;
  sorted.forEach((v, i) => { v.order = i + 1; });
  saveData(data); refreshAll();
}
function deleteVehicle(id) {
  if (!confirm('차량을 삭제할까요?')) return;
  const data = loadData();
  data.vehicles = (data.vehicles || []).filter(v => v.id !== id);
  // order 재정렬
  data.vehicles.sort((a, b) => (a.order || 9999) - (b.order || 9999))
    .forEach((v, i) => { v.order = i + 1; });
  saveData(data); refreshAll();
}
function setVehicleOrder(id, val) {
  const newOrder = parseInt(val, 10);
  const data = loadData();
  const sorted = (data.vehicles || []).slice().sort((a, b) => (a.order || 9999) - (b.order || 9999));
  const total = sorted.length;
  if (isNaN(newOrder) || newOrder < 1 || newOrder > total) {
    alert(`순번은 1~${total} 사이여야 합니다`);
    refreshAll();
    return;
  }
  const idx = sorted.findIndex(v => v.id === id);
  if (idx < 0) return;
  const v = sorted.splice(idx, 1)[0];
  sorted.splice(newOrder - 1, 0, v);
  sorted.forEach((vv, i) => { vv.order = i + 1; });
  saveData(data); refreshAll();
}
