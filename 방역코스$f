      '운전자': drvM?.name || v.defaultDriverName || '',
      '운전자연락처': drvM?.phone || v.defaultDriverPhone || '',
      '보조자': astM?.name || v.defaultAssistName || '',
      '보조자연락처': astM?.phone || v.defaultAssistPhone || ''
