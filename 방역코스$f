<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <title>인원관리</title>
  <link rel="stylesheet" href="style.css?v=20260512v">
  <style>body.viewer-mode .admin-only { display: none !important; }</style>
</head>
<body>
<header>
  <h1>👥 인원관리</h1>
  <nav>
    <a href="index.html">홈</a>
    <a href="admin.html">관리</a>
    <a href="members.html" class="active">인원</a>
    <a href="today.html">오늘운영</a>
    <a href="monitor.html">모니터링</a>
    <a href="stats.html">통계</a>
    <a href="accounts.html">계정</a>
    <a href="#" onclick="adminLogout();return false;">로그아웃</a>
  </nav>
</header>

<div class="container">
  <div class="row">
    <!-- 회원 목록 -->
    <div class="col" style="flex:1;min-width:320px;">
      <div class="card">
        <div class="flex-between"><h2>회원 목록 <span id="memberCount" class="muted"></span></h2>
          <div class="admin-only">
            <button class="small" onclick="addMember()">+ 추가</button>
          </div>
        </div>
        <div class="admin-only" style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px;">
          <button class="small gray" onclick="downloadMemberTemplate()">📄 양식</button>
          <button class="small gray" onclick="exportMembersCSV()">⬇️ 다운로드</button>
          <button class="small gray" onclick="document.getElementById('memUpload').click()">📤 엑셀 업로드</button>
          <button class="small gray" onclick="bulkImportMembers()">📋 붙여넣기</button>
          <button class="small success" onclick="makeAllMemberAccounts()">🔑 계정 일괄생성</button>
          <button class="small danger" onclick="deleteAllMembers()">🗑 전체 삭제</button>
        </div>
        <input type="file" id="memUpload" accept=".csv,.xlsx,.xls" style="display:none">
        <div style="display:flex;gap:4px;margin-bottom:8px;">
          <input id="memSearch" type="text" placeholder="이름 검색..." oninput="renderMembers()" style="flex:1;">
          <select id="posFilter" onchange="renderMembers()" style="width:auto;">
            <option value="">모든 직책</option>
          </select>
        </div>
        <div id="memberList" style="max-height:600px;overflow-y:auto;"></div>
      </div>
    </div>

    <!-- 조 편성 -->
    <div class="col" style="flex:2;min-width:400px;">
      <div class="card">
        <div class="flex-between">
          <h2>방역조 편성</h2>
          <div class="admin-only">
            <button onclick="randomAssign()" class="success">🎲 팀짜기</button>
            <button onclick="saveTeamSnapshot()">💾 현재 팀 저장</button>
            <button onclick="exportTeamsExcel()" class="small" style="background:#27ae60;color:#fff;">⬇ 조 내보내기</button>
            <button onclick="document.getElementById('teamUpload').click()" class="small" style="background:#3498db;color:#fff;">📤 조 불러오기</button>
            <button onclick="resetTeams()" class="gray small">조원 리셋</button>
            <input type="file" id="teamUpload" accept=".xlsx,.xls,.csv" style="display:none" onchange="importTeamsExcel(event)">
          </div>
        </div>
        <p class="muted" style="font-size:12px;">조장·부조장 고정 / 📌 = 고정 조원 / 팀짜기 = 나머지 랜덤 분배</p>
        <div id="teamPanels" style="margin-top:10px;"></div>
      </div>

      <div class="card">
        <h2>저장된 팀 구성 <span id="savedCount" class="muted"></span></h2>
        <p class="muted" style="font-size:12px;">팀 구성을 저장해두고 나중에 불러올 수 있습니다 (이전 구성 비교/복원용)</p>
        <div id="savedTeamsList"></div>
      </div>

      <!-- 차량 등록 -->
      <div class="card" style="border-left:4px solid #e67e22;">
        <div class="flex-between">
          <h2>🚐 차량 등록</h2>
          <div class="admin-only" style="display:flex;gap:4px;flex-wrap:wrap;">
            <button class="small success" onclick="setAllVehiclesActive(true)" title="차량 모두 활성화 → 오늘운영에서 차량 버튼만 표시 (조 입력 비활성화)">🚐 차량 활성화 <span style="opacity:0.85;font-weight:400;">(조 입력 OFF)</span></button>
            <button class="small gray" onclick="setAllVehiclesActive(false)" title="차량 모두 비활성화 → 오늘운영에서 조 입력 폼 표시 (차량 버튼 비활성화)">🧑 차량 비활성화 <span style="opacity:0.85;font-weight:400;">(조 입력 ON)</span></button>
            <button class="small" onclick="printAllVehicles()">🖨 전체 호차 인쇄</button>
            <button onclick="exportVehiclesExcel()" class="small" style="background:#27ae60;color:#fff;">⬇ 차량 내보내기</button>
            <button onclick="document.getElementById('vehUpload').click()" class="small" style="background:#3498db;color:#fff;">📤 차량 불러오기</button>
            <input type="file" id="vehUpload" accept=".xlsx,.xls,.csv" style="display:none" onchange="importVehiclesExcel(event)">
            <button class="small success" onclick="addVehicle()">+ 차량 추가</button>
          </div>
        </div>
        <p class="muted" style="font-size:12px;">차량별 운전자/보조 등록. today.html 에서 차량 선택하면 자동으로 운전자가 채워집니다. 각 카드 <b>🖨</b>로 한 대씩 또는 <b>전체 호차 인쇄</b>로 A4 출력.</p>
        <div id="vehicleList"></div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-database-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-auth-compat.js"></script>
<script src="firebase-config.js?v=20260512v"></script>
<script src="common.js?v=20260608c"></script>
<script>
window.onAuthSuccess = () => onDataReady(refreshAll);
window.onDataChanged = () => refreshAll();
checkAdminAuth().then(ok => { if (ok) onDataReady(refreshAll); });

// 권한에 따라 isAdmin 결정 (viewer면 조회만)
let isAdmin = true;

function refreshAll() {
  // 입력 중인 필드 포커스 복원 — 차량 카드 인라인 입력이 자꾸 풀리지 않게
  const ae = document.activeElement;
  const fid = ae && ae.id ? ae.id : '';
  const ss = ae && ae.selectionStart, se = ae && ae.selectionEnd;

  document.body.classList.toggle('viewer-mode', !isAdmin);
  renderMembers();
  renderTeams();
  renderSavedTeams();
  renderVehicles();

  if (fid) {
    const el = document.getElementById(fid);
    if (el && el.focus) {
      el.focus();
      try { if (typeof ss === 'number') el.setSelectionRange(ss, se); } catch (e) {}
    }
  }
}

// ────── 차량 등록 ──────
function renderVehicles() {
  const data = loadData();
  const vehicles = (data.vehicles || []).slice().sort((a, b) => (a.order || 9999) - (b.order || 9999));
  const el = document.getElementById('vehicleList');
  if (!el) return;
  if (!vehicles.length) {
    el.innerHTML = '<div class="empty">등록된 차량이 없습니다. <b>+ 차량 추가</b> 클릭</div>';
    return;
  }
  const total = vehicles.length;

  let activeCount = 0;
  el.innerHTML = vehicles.map((v, idx) => {
    const isActive = v.active !== false && v.active !== 'false';
    if (isActive) activeCount++;
    const displayName = isActive ? `${activeCount}호차` : `비활성`;  // 항상 N호차 표시
    // 운전자/보조 정보 추출 (회원 또는 외부)
    const drvMember = getMember(data, v.defaultDriverId);
    const astMember = getMember(data, v.defaultAssistId);
    const drvName = drvMember?.name || v.defaultDriverName || '';
    const drvPhone = drvMember?.phone || v.defaultDriverPhone || '';
    const drvIsExt = !drvMember && !!v.defaultDriverName;
    const astName = astMember?.name || v.defaultAssistName || '';
    const astPhone = astMember?.phone || v.defaultAssistPhone || '';
    const astIsExt = !astMember && !!v.defaultAssistName;
    const phoneLink = (ph) => ph
      ? `<a href="tel:${ph.replace(/[^0-9+]/g,'')}" style="color:#3498db;text-decoration:none;font-family:monospace;" onclick="event.stopPropagation()">📞 ${ph.replace(/</g,'&lt;')}</a>`
      : '';
    return `
      <div class="vehicle-card" style="border:1px solid ${isActive ? '#f0d4b3' : '#ddd'};border-radius:8px;padding:10px 12px;margin-bottom:8px;background:${isActive ? '#fffaf3' : '#f5f5f5'};${isActive ? '' : 'opacity:0.7;'}">
        <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
          <button class="small gray" onclick="moveVehicle('${v.id}', -1)" style="padding:2px 7px;font-size:13px;">▲</button>
          <button class="small gray" onclick="moveVehicle('${v.id}', 1)" style="padding:2px 7px;font-size:13px;">▼</button>
          <span style="background:${isActive ? '#e67e22' : '#bdc3c7'};color:#fff;padding:6px 14px;border-radius:6px;font-weight:700;font-size:16px;">🚐 ${displayName}</span>
          <span style="flex:1;"></span>
          <button onclick="toggleVehicleActive('${v.id}')"
                  title="${isActive ? '활성화 — 클릭하면 비활성화 (오늘운영에서 숨김)' : '비활성화 — 클릭하면 활성화 (오늘운영에 표시)'}"
                  style="background:${isActive ? '#27ae60' : '#95a5a6'};color:#fff;border:none;padding:6px 12px;border-radius:5px;font-weight:700;font-size:12px;cursor:pointer;">
            ${isActive ? '✅ 활성' : '🚫 비활성'}
          </button>
          <button class="small" onclick="printOneVehicle('${v.id}')" title="이 차량 호차 A4 인쇄">🖨</button>
          <button class="small" onclick="editVehicle('${v.id}')">✎ 수정</button>
          <button class="small danger" onclick="deleteVehicle('${v.id}')">🗑</button>
        </div>
        <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:10px;font-size:13px;color:#34495e;">
          ${v.plate ? `<span>🔖 <b style="font-family:monospace;">${v.plate.replace(/</g,'&lt;')}</b></span>` : ''}
          ${v.color ? `<span>🎨 ${v.color.replace(/</g,'&lt;')}</span>` : ''}
          ${v.owner ? `<span>🏢 ${v.owner.replace(/</g,'&lt;')}${v.ownerPhone ? ' · ' + phoneLink(v.ownerPhone) : ''}</span>` : ''}
        </div>
        <div style="margin-top:6px;font-size:13px;color:#34495e;">
          🧑‍✈️ <b>운전:</b> ${drvName ? drvName.replace(/</g,'&lt;') + (drvIsExt ? ' <span style="font-size:10px;color:#888;">(외부)</span>' : '') : '<span style="color:#bbb;">미지정</span>'}
          ${phoneLink(drvPhone) ? ' · ' + phoneLink(drvPhone) : ''}
        </div>
        <div style="margin-top:4px;font-size:13px;color:#34495e;">
          🧑 <b>보조:</b> ${astName ? astName.replace(/</g,'&lt;') + (astIsExt ? ' <span style="font-size:10px;color:#888;">(외부)</span>' : '') : '<span style="color:#bbb;">미지정</span>'}
          ${phoneLink(astPhone) ? ' · ' + phoneLink(astPhone) : ''}
        </div>
        <div style="margin-top:6px;display:flex;flex-wrap:wrap;gap:6px;align-items:center;">
          <span style="font-size:11px;color:#888;font-weight:600;">행사:</span>
          ${(data.events||[]).map(ev => {
            const cfg = (data.eventConfig||{})[ev.id] || {};
            const vehs = Array.isArray(cfg.vehicles) ? cfg.vehicles : [];
            const on = vehs.indexOf(v.id) >= 0;
            return '<label style="display:inline-flex;align-items:center;gap:3px;font-size:12px;padding:3px 8px;border:1px solid '+(on?'#e67e22':'#ddd')+';border-radius:12px;background:'+(on?'#fef5ec':'#f9f9f9')+';cursor:pointer;">'
              +'<input type="checkbox" '+(on?'checked':'')+' onchange="toggleVehEvent(\''+v.id+'\',\''+ev.id+'\')" style="width:14px;height:14px;">'
              +'<span>'+ev.name.replace(/</g,'&lt;')+'</span></label>';
          }).join('')}
        </div>
      </div>
    `;
  }).join('');
}
function addVehicle() {
  openVehicleModal(null);  // 빈 모달
}
function editVehicle(id) {
  openVehicleModal(id);
}

// 차량 추가/수정 모달 — 한 화면에 모든 항목
function openVehicleModal(editId) {
  const data = loadData();
  const isEdit = !!editId;
  const v = isEdit ? (data.vehicles || []).find(x => x.id === editId) : null;
  const nextOrder = isEdit ? (v.order || 1) : ((data.vehicles?.length ? Math.max(...data.vehicles.map(v => v.order || 0)) : 0) + 1);
  const memberOpts = (data.members || [])
    .map(m => `<option value="${m.id}">${(m.name||'')}${m.phone ? ' ('+m.phone+')' : ''}</option>`).join('');
  const drvSel = isEdit && v.defaultDriverId ? v.defaultDriverId : '';
  const astSel = isEdit && v.defaultAssistId ? v.defaultAssistId : '';
  const drvIsExt = !!(isEdit && !v.defaultDriverId && (v.defaultDriverName || v.defaultDriverPhone));
  const astIsExt = !!(isEdit && !v.defaultAssistId && (v.defaultAssistName || v.defaultAssistPhone));

  const overlay = document.createElement('div');
  overlay.id = 'vehicleModalOverlay';
  overlay.style.cssText = 'position:fixed;inset:0;background:rgba(44,62,80,0.7);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px;';
  overlay.innerHTML = `
    <div style="background:#fff;border-radius:10px;padding:20px;max-width:420px;width:100%;max-height:90vh;overflow-y:auto;">
      <h2 style="margin:0 0 14px;color:#e67e22;">🚐 ${nextOrder}호차 ${isEdit ? '수정' : '추가'}</h2>

      <label style="font-size:12px;color:#555;">색상</label>
      <input id="vmColor" type="text" placeholder="예: 흰색, 카니발 흰색" value="${isEdit ? (v.color||'').replace(/"/g,'&quot;') : ''}" autocomplete="off" style="width:100%;font-size:14px;margin-bottom:10px;box-sizing:border-box;">

      <label style="font-size:12px;color:#555;">차번호</label>
      <input id="vmPlate" type="text" placeholder="예: 12가 3456" value="${isEdit ? (v.plate||'').replace(/"/g,'&quot;') : ''}" autocomplete="off" style="width:100%;font-size:14px;margin-bottom:10px;box-sizing:border-box;">

      <label style="font-size:12px;color:#555;">보험사 / 소유주</label>
      <input id="vmOwner" type="text" placeholder="예: DB손보 홍길동" value="${isEdit ? (v.owner||'').replace(/"/g,'&quot;') : ''}" autocomplete="off" style="width:100%;font-size:14px;margin-bottom:10px;box-sizing:border-box;">

      <label style="font-size:12px;color:#555;">보험사(소유주) 연락처</label>
      <input id="vmOwnerPhone" type="tel" placeholder="예: 010-1234-5678" value="${isEdit ? (v.ownerPhone||'').replace(/"/g,'&quot;') : ''}" autocomplete="off" style="width:100%;font-size:14px;margin-bottom:14px;box-sizing:border-box;">

      <div style="background:#f8f9fa;padding:10px;border-radius:6px;margin-bottom:10px;">
        <label style="font-size:13px;font-weight:700;color:#34495e;">🧑‍✈️ 운전자</label>
        <select id="vmDrv" style="width:100%;margin-top:4px;font-size:13px;" onchange="vmToggleExt('Drv')">
          <option value="">- 미지정 -</option>
          <option value="__external__"${drvIsExt ? ' selected' : ''}>+ 외부인원 직접입력</option>
          ${memberOpts.replace(`value="${drvSel}"`, `value="${drvSel}" selected`)}
        </select>
        <div id="vmDrvExtBox" style="display:${drvIsExt ? 'block' : 'none'};margin-top:6px;">
          <input id="vmDrvExtName" type="text" placeholder="외부인원 이름" value="${isEdit ? (v.defaultDriverName||'').replace(/"/g,'&quot;') : ''}" autocomplete="off" style="width:100%;font-size:13px;margin-bottom:4px;box-sizing:border-box;">
          <input id="vmDrvExtPhone" type="tel" placeholder="010-1234-5678" value="${isEdit ? (v.defaultDriverPhone||'').replace(/"/g,'&quot;') : ''}" autocomplete="off" style="width:100%;font-size:13px;box-sizing:border-box;">
        </div>
      </div>

      <div style="background:#f8f9fa;padding:10px;border-radius:6px;margin-bottom:14px;">
        <label style="font-size:13px;font-weight:700;color:#34495e;">🧑 보조 (선택)</label>
        <select id="vmAst" style="width:100%;margin-top:4px;font-size:13px;" onchange="vmToggleExt('Ast')">
          <option value="">- 미지정 -</option>
          <option value="__external__"${astIsExt ? ' selected' : ''}>+ 외부인원 직접입력</option>
          ${memberOpts.replace(`value="${astSel}"`, `value="${astSel}" selected`)}
        </select>
        <div id="vmAstExtBox" style="display:${astIsExt ? 'block' : 'none'};margin-top:6px;">
          <input id="vmAstExtName" type="text" placeholder="외부인원 이름" value="${isEdit ? (v.defaultAssistName||'').replace(/"/g,'&quot;') : ''}" autocomplete="off" style="width:100%;font-size:13px;margin-bottom:4px;box-sizing:border-box;">
          <input id="vmAstExtPhone" type="tel" placeholder="010-1234-5678" value="${isEdit ? (v.defaultAssistPhone||'').replace(/"/g,'&quot;') : ''}" autocomplete="off" style="width:100%;font-size:13px;box-sizing:border-box;">
        </div>
      </div>

      <div style="display:flex;gap:6px;">
        <button class="success" style="flex:1;padding:10px;font-weight:700;" onclick="saveVehicleModal('${editId || ''}')">${isEdit ? '💾 저장' : '+ 추가'}</button>
        <button class="gray" style="padding:10px 14px;" onclick="closeVehicleModal()">취소</button>
      </div>
    </div>
  `;
  document.body.appendChild(overlay);
  setTimeout(() => document.getElementById('vmColor').focus(), 100);
  overlay.onclick = (e) => { if (e.target === overlay) closeVehicleModal(); };
  document.addEventListener('keydown', vehicleModalKeydown);
}
function vmToggleExt(prefix) {
  const sel = document.getElementById('vm' + prefix);
  const box = document.getElementById('vm' + prefix + 'ExtBox');
  if (!sel || !box) return;
  const isExt = sel.value === '__external__';
  box.style.display = isExt ? 'block' : 'none';
  if (isExt) {
    setTimeout(() => {
      const inp = document.getElementById('vm' + prefix + 'ExtName');
      if (inp) inp.focus();
    }, 50);
  }
}
function vehicleModalKeydown(e) {
  if (e.key === 'Escape') closeVehicleModal();
}
function closeVehicleModal() {
  const ov = document.getElementById('vehicleModalOverlay');
  if (ov) ov.remove();
  document.removeEventListener('keydown', vehicleModalKeydown);
}
function saveVehicleModal(editId) {
  const color = (document.getElementById('vmColor').value || '').trim();
  const plate = (document.getElementById('vmPlate').value || '').trim();
  const owner = (document.getElementById('vmOwner').value || '').trim();
  const ownerPhone = (document.getElementById('vmOwnerPhone').value || '').trim();
  const drvVal = document.getElementById('vmDrv').value;
  const astVal = document.getElementById('vmAst').value;
  const drvExtName = (document.getElementById('vmDrvExtName')?.value || '').trim();
  const drvExtPhone = (document.getElementById('vmDrvExtPhone')?.value || '').trim();
  const astExtName = (document.getElementById('vmAstExtName')?.value || '').trim();
  const astExtPhone = (document.getElementById('vmAstExtPhone')?.value || '').trim();

  const data = loadData();
  if (!data.vehicles) data.vehicles = [];
  let v;
  if (editId) {
    v = data.vehicles.find(x => x.id === editId);
    if (!v) { alert('차량을 찾을 수 없습니다'); return; }
  } else {
    const nextOrder = (data.vehicles.length ? Math.max(...data.vehicles.map(vv => vv.order || 0)) : 0) + 1;
    v = {
      id: uid(), order: nextOrder, memberIds: [],
      defaultDriverId:'', defaultAssistId:'',
      defaultDriverName:'', defaultDriverPhone:'',
      defaultAssistName:'', defaultAssistPhone:''
    };
    data.vehicles.push(v);
  }
  v.color = color;
  v.plate = plate;
  v.owner = owner;
  v.ownerPhone = ownerPhone;
  v.name = `${v.order || 1}호차`;  // 항상 N호차로 표시
  // 운전자
  if (drvVal === '__external__') {
    v.defaultDriverId = '';
    v.defaultDriverName = drvExtName;
    v.defaultDriverPhone = drvExtPhone;
  } else {
    v.defaultDriverId = drvVal || '';
    v.defaultDriverName = ''; v.defaultDriverPhone = '';
  }
  // 보조
  if (astVal === '__external__') {
    v.defaultAssistId = '';
