function importVehiclesExcel(e) {
  const file = e.target.files[0];
  e.target.value = '';
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(ev) {
    try {
      const wb = XLSX.read(ev.target.result, { type: 'array' });
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws);
      if (!rows.length) { alert('데이터가 없습니다'); return; }
      const data = loadData();
      if (!data.vehicles) data.vehicles = [];
      const members = data.members || [];
      const findMember = name => {
        const n = String(name || '').trim();
        if (!n) return null;
        return members.find(m => (m.name || '').trim() === n);
      };
      let updated = 0, created = 0;
      const maxOrder = data.vehicles.length ? Math.max(...data.vehicles.map(v => v.order || 0)) : 0;
      rows.forEach((r, idx) => {
        const color = String(r['색상'] || '').trim();
        const plate = String(r['차번호'] || '').trim();
        const owner = String(r['소유주'] || '').trim();
        const ownerPhone = String(r['소유주연락처'] || '').trim();
        const drvName = String(r['운전자'] || '').trim();
        const drvPhone = String(r['운전자연락처'] || '').trim();
        const astName = String(r['보조자'] || '').trim();
        const astPhone = String(r['보조자연락처'] || '').trim();
        const statusStr = String(r['상태'] || '').trim();
        // 기존 차량 매칭: 차번호 일치 또는 같은 순번
        let v = null;
        if (plate) v = data.vehicles.find(x => x.plate === plate);
        if (!v) {
          // 순번(order)으로 매칭
          const order = idx + 1;
          v = data.vehicles.find(x => x.order === order);
        }
        if (v) {
          // 기존 업데이트
          if (color) v.color = color;
          if (plate) v.plate = plate;
          if (owner) v.owner = owner;
          if (ownerPhone) v.ownerPhone = ownerPhone;
          if (statusStr === '비활성') v.active = false;
          else if (statusStr === '활성') v.active = true;
          // 운전자
          const drvM = findMember(drvName);
          if (drvM) { v.defaultDriverId = drvM.id; v.defaultDriverName = ''; v.defaultDriverPhone = ''; }
          else if (drvName) { v.defaultDriverId = ''; v.defaultDriverName = drvName; v.defaultDriverPhone = drvPhone; }
          // 보조자
          const astM = findMember(astName);
          if (astM) { v.defaultAssistId = astM.id; v.defaultAssistName = ''; v.defaultAssistPhone = ''; }
          else if (astName) { v.defaultAssistId = ''; v.defaultAssistName = astName; v.defaultAssistPhone = astPhone; }
          updated++;
        } else {
          // 새 차량 생성
          const newOrder = maxOrder + idx + 1;
          const newV = {
            id: uid(), order: newOrder, active: statusStr !== '비활성',
            color, plate, owner, ownerPhone,
            name: newOrder + '호차', memberIds: [],
            defaultDriverId: '', defaultAssistId: '',
            defaultDriverName: '', defaultDriverPhone: '',
            defaultAssistName: '', defaultAssistPhone: ''
          };
          const drvM = findMember(drvName);
          if (drvM) newV.defaultDriverId = drvM.id;
          else if (drvName) { newV.defaultDriverName = drvName; newV.defaultDriverPhone = drvPhone; }
          const astM = findMember(astName);
          if (astM) newV.defaultAssistId = astM.id;
          else if (astName) { newV.defaultAssistName = astName; newV.defaultAssistPhone = astPhone; }
          data.vehicles.push(newV);
          created++;
        }
      });
      saveData(data); refreshAll();
      alert(`✅ 차량 불러오기 완료\n업데이트: ${updated}대, 새로 추가: ${created}대`);
    } catch (err) {
      alert('파일 읽기 실패: ' + err.message);
    }
  };
  reader.readAsArrayBuffer(file);
}

// ────── 회원 ──────
// 직책 정렬 순서 (사용자 요청: 회장→부회장→감사→사무국장→재무국장→재무차장→...→회원)
const POSITION_ORDER = [
  '회장','부회장','감사',
  '사무국장','사무차장',
  '재무국장','재무차장',
  '홍보국장','홍보차장',
  '기획국장','기획차장',
  '총무','이장',
  '전임회장',
  '회원','일반회원',''
];
function positionRank(p) {
  const i = POSITION_ORDER.indexOf((p || '').trim());
  return i === -1 ? POSITION_ORDER.length : i;
}

function renderMembers() {
  const data = loadData();
  const q = (document.getElementById('memSearch')?.value || '').toLowerCase();
  const posFilter = document.getElementById('posFilter')?.value || '';
  const allMembers = data.members || [];

  // 직책 드롭다운 채우기
  const positions = [...new Set(allMembers.map(m => m.position || '').filter(Boolean))]
    .sort((a, b) => positionRank(a) - positionRank(b));
  const posSel = document.getElementById('posFilter');
  if (posSel) {
    const cur = posSel.value;
    posSel.innerHTML = '<option value="">모든 직책</option>' +
      positions.map(p => `<option value="${p}">${p}</option>`).join('');
    if (cur) posSel.value = cur;
  }

  const members = allMembers
    .filter(m => !q || (m.name||'').toLowerCase().includes(q))
    .filter(m => !posFilter || (m.position||'') === posFilter)
    .sort((a, b) =>
      positionRank(a.position) - positionRank(b.position) ||
      // rank가 같으면 직책 문자열로 한 번 더 묶기 (전임회장이 회원 사이에 끼어들지 않게)
      (a.position || '').localeCompare(b.position || '') ||
      (a.name || '').localeCompare(b.name || '')
    );

  document.getElementById('memberCount').textContent = `(${allMembers.length}명)`;

  if (!members.length) {
    document.getElementById('memberList').innerHTML = '<div class="empty">회원이 없습니다</div>';
    return;
  }

  // 어느 조에 속해있는지 매핑
  const assignedTo = {};
  for (const t of (data.teams || [])) {
    if (t.leaderId) assignedTo[t.leaderId] = `${t.name} 조장`;
    if (t.viceLeaderId) assignedTo[t.viceLeaderId] = `${t.name} 부조장`;
    for (const id of (t.memberIds || [])) assignedTo[id] = `${t.name} 조원`;
  }

  // memberId ↔ uid 매핑 (계정 있는지 확인용)
  const memberAuth = data.memberAuth || {};
  const memberUidByMemberId = {};
  for (const [uid, mid] of Object.entries(memberAuth)) memberUidByMemberId[mid] = uid;

  // 직책별 그룹화
  let html = '';
  let currentGroup = null;
  for (const m of members) {
    const pos = m.position || '일반회원';
    if (pos !== currentGroup) {
      if (currentGroup !== null) html += '</div>';
      currentGroup = pos;
      const groupCount = members.filter(x => (x.position || '일반회원') === pos).length;
      html += `<h3 style="margin:12px 0 6px;color:#34495e;border-bottom:2px solid #34495e;padding-bottom:4px;">${pos} <span class="muted" style="font-size:11px;">(${groupCount}명)</span></h3><div>`;
    }
    const hasAccount = !!memberUidByMemberId[m.id];
    const phoneTel = (m.phone || '').replace(/[^0-9+]/g, '');
    const phoneHtml = m.phone
      ? `<a href="tel:${phoneTel}" style="color:#3498db;text-decoration:none;" onclick="event.stopPropagation()">📞 ${m.phone}</a>`
      : '';
    const posTag = m.position
      ? ` <span class="tag" style="background:#34495e;color:#fff;">${m.position}</span>`
      : '';
    html += `
      <div class="list-item">
        <div class="info">
          <div class="name">${m.name}${posTag} <span class="sub">${phoneHtml}</span> ${hasAccount ? '<span class="tag" style="background:#27ae60">🔑</span>' : ''}</div>
          <div class="sub">${assignedTo[m.id] || '<span style="color:#aaa;">조 미배정</span>'}${m.birthday ? ' · 🎂 ' + m.birthday : ''}${m.address ? ' · 📍 ' + m.address : ''}${m.note ? ' · ' + m.note : ''}</div>
        </div>
        <span class="admin-only">
          ${hasAccount
            ? `<button class="small gray" onclick="resetMemberPin('${m.id}')">PIN</button>`
            : `<button class="small success" onclick="makeMemberAccount('${m.id}')">계정</button>`}
