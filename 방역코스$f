function bulkImportMembers() {
  const text = prompt(
    '회원 데이터 붙여넣기\n\n' +
    '형식: 한 줄에 한 명, 탭(Tab) 또는 쉼표로 구분\n' +
    '   이름   연락처   메모\n\n' +
    '예시:\n' +
    '홍길동\\t010-1234-5678\\t조장\n' +
    '김철수\\t010-2222-3333\\t\n\n' +
    '구글 시트나 엑셀에서 복사한 내용 그대로 붙여넣으면 됩니다.'
  );
  if (!text) return;

  const lines = text.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
  if (!lines.length) { alert('데이터가 없습니다'); return; }

  const data = loadData();
  if (!data.members) data.members = [];
  const existing = new Set(data.members.map(m => m.name + '|' + (m.phone || '')));

  let added = 0, skipped = 0;
  for (const line of lines) {
    // 탭 우선, 그 다음 쉼표
    const cells = line.includes('\t') ? line.split('\t') : line.split(',');
    const name = (cells[0] || '').trim();
    const phone = (cells[1] || '').trim();
    const note = (cells[2] || '').trim();
    if (!name) { skipped++; continue; }
    const key = name + '|' + phone;
    if (existing.has(key)) { skipped++; continue; }
    data.members.push({ id: uid(), name, phone, note });
    existing.add(key);
    added++;
  }
  saveData(data);
  alert(`✅ ${added}명 추가\n⏭ ${skipped}명 건너뜀 (이름 없음 또는 중복)`);
}

