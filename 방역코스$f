function csvEscape(s) {
  s = String(s || '');
  if (s.includes(',') || s.includes('"') || s.includes('\n')) {
    return '"' + s.replace(/"/g, '""') + '"';
  }
  return s;
}

function downloadCSVFile(content, filename) {
  const blob = new Blob([content], { type: 'text/csv;charset=utf-8' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = filename;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
}

document.getElementById('memUpload').addEventListener('change', async (e) => {
  const file = e.target.files[0];
  if (!file) return;
  e.target.value = '';

  // Firebase 데이터 동기화 전에는 업로드 금지 — 빈 캐시로 저장하면 전체 DB가 날아감
  if (typeof _cache === 'undefined' || !_cache) {
    alert('⚠️ 데이터 동기화 중입니다. 잠시 후 다시 시도해주세요.\n(업로드를 지금 하면 기존 데이터가 사라질 수 있어요)');
    return;
  }

  let rows;
  try {
    if (file.name.match(/\.(xlsx|xls)$/i)) {
      const buf = await file.arrayBuffer();
      const wb = XLSX.read(buf, { type: 'array' });
      const ws = wb.Sheets[wb.SheetNames[0]];
      rows = XLSX.utils.sheet_to_json(ws, { defval: '' });
    } else {
      // CSV: UTF-8 우선, 깨지면 EUC-KR 폴백 (한글 엑셀 "CSV로 저장" 기본 인코딩)
      const buf = await file.arrayBuffer();
      let text;
      try {
        text = new TextDecoder('utf-8', { fatal: true }).decode(buf);
      } catch (e) {
        try { text = new TextDecoder('euc-kr').decode(buf); }
        catch (e2) { text = new TextDecoder('utf-8').decode(buf); }
      }
      rows = parseCSVMembers(text);
    }
  } catch (err) {
    alert('파일 읽기 실패: ' + err.message); return;
  }

  if (!rows.length) { alert('데이터 없음'); return; }

  const data = loadData();
  if (!data.members) data.members = [];
  const existing = new Set(data.members.map(m => m.name + '|' + (m.phone || '')));
  let added = 0, skipped = 0;
  // 헤더 키를 trim/소문자 통일해서 한 번 정규화 → 매칭
  const normRows = rows.map(r => {
    const o = {};
    for (const k of Object.keys(r)) {
      o[String(k).trim().toLowerCase()] = r[k];
    }
    return o;
  });
  // 헤더 안에 키워드가 포함되어 있으면 매칭 (느슨하게)
  const findByKeyword = (row, keywords) => {
    for (const kw of keywords) {
      for (const k of Object.keys(row)) {
        if (k.includes(kw) && row[k] !== undefined && row[k] !== '') return row[k];
      }
    }
    return '';
  };
  const pick = (row, ...keywords) => findByKeyword(row, keywords.map(s => s.toLowerCase()));
  rows = normRows;
  // 핸드폰 번호 정리: 앞 0 복원, 하이픈 보존
  const normalizePhone = (v) => {
    let s = String(v == null ? '' : v).trim();
    if (!s) return '';
    // 엑셀이 숫자로 저장한 경우 앞 0 빠짐 → 010, 011 패턴 복원 시도
    const digits = s.replace(/\D/g, '');
    if (digits && !s.startsWith('0') && digits.length >= 9 && digits.length <= 10) {
      return '0' + digits;
    }
    return s;
  };
  // 엑셀 날짜 시리얼(숫자) → YYYY-MM-DD
  const normalizeDate = (v) => {
    if (v == null || v === '') return '';
    if (typeof v === 'number') {
      // 엑셀 epoch: 1900-01-00
      const d = new Date(Math.round((v - 25569) * 86400 * 1000));
      if (!isNaN(d)) return d.toISOString().slice(0, 10);
    }
    return String(v).trim();
  };

  const sampleAdded = [];
  // 첫 행 헤더 디버그용
  const firstHeaders = rows.length ? Object.keys(rows[0]).join(', ') : '(없음)';
  // 직책으로 알려진 단어 — 헤더 라벨이 잘못된 파일 자동 보정용
  const KNOWN_POSITIONS = new Set([
    '회장','부회장','감사','사무국장','사무차장','재무국장','재무차장',
    '홍보국장','홍보차장','기획국장','기획차장','총무','이장','부녀회장',
    '청년회장','일반회원','회원','조장','부조장','새마을','노인회장'
  ]);
  let swapCount = 0;
  for (const row of rows) {
    let name = String(pick(row, '이름', '성명', '회원', 'name')).trim();
    let position = String(pick(row, '직책', '직급', '직위', '소속', '담당', 'position', 'role')).trim();
    // 헤더 라벨이 뒤바뀐 파일 자동 보정 — name이 직책 단어면 swap
    if (name && KNOWN_POSITIONS.has(name) && position && !KNOWN_POSITIONS.has(position)) {
      [name, position] = [position, name];
      swapCount++;
    }
    const phone = normalizePhone(pick(row, '연락처', '연락', '전화', '핸드폰', '휴대폰', '번호', 'phone', 'tel', 'mobile'));
    const birthday = normalizeDate(pick(row, '생년월일', '생일', '나이', 'birth'));
    const address = String(pick(row, '주소', '거주지', 'address', 'addr')).trim();
    const note = String(pick(row, '메모', '비고', '특이', 'note', 'memo')).trim();
    if (!name) { skipped++; continue; }
    const key = name + '|' + phone;
    if (existing.has(key)) { skipped++; continue; }
    data.members.push({ id: uid(), name, position, phone, birthday, address, note });
    existing.add(key);
    added++;
    if (sampleAdded.length < 3) sampleAdded.push(`${position?position+' ':''}${name} ${phone}`);
  }
  saveData(data);
  let msg = `✅ ${added}명 추가\n⏭ ${skipped}명 건너뜀 (이름없음 또는 중복)`;
  if (swapCount > 0) msg += `\n🔄 이름/직책 컬럼이 뒤바뀌어 있어서 자동 보정 (${swapCount}명)`;
  if (added > 0) msg += `\n\n샘플:\n${sampleAdded.join('\n')}`;
  if (added === 0) {
    msg += `\n\n⚠️ 한 명도 등록 안됨. 파일 첫 행 컬럼명 확인:\n[${firstHeaders}]\n\n→ "이름" 비슷한 컬럼이 있어야 함\n→ 양식 다운로드해서 컬럼 맞추거나, 알려주시면 코드에 그 이름 추가`;
  }
  alert(msg);
});

// 따옴표/콤마/탭 들어간 필드 안전 파싱 + 자동 구분자 감지 (콤마 vs 탭)
function parseCSVMembers(text) {
  text = text.replace(/^﻿/, '');
  // 첫 줄에서 구분자 감지 — 탭이 더 많으면 TSV로 간주
  const firstLine = text.split(/\r?\n/, 1)[0] || '';
  const tabCount = (firstLine.match(/\t/g) || []).length;
  const commaCount = (firstLine.match(/,/g) || []).length;
  const sep = (tabCount > commaCount) ? '\t' : ',';
  const rows = [];
  let cur = [], cell = '', inQ = false;
  for (let i = 0; i < text.length; i++) {
    const ch = text[i];
    if (inQ) {
      if (ch === '"') {
        if (text[i+1] === '"') { cell += '"'; i++; }
        else inQ = false;
      } else cell += ch;
    } else {
      if (ch === '"') inQ = true;
      else if (ch === sep) { cur.push(cell); cell = ''; }
      else if (ch === '\r') {/* skip */}
      else if (ch === '\n') { cur.push(cell); rows.push(cur); cur = []; cell = ''; }
      else cell += ch;
    }
  }
  if (cell !== '' || cur.length) { cur.push(cell); rows.push(cur); }
  // 빈 줄 제거
  const nonEmpty = rows.filter(r => r.some(c => String(c).trim() !== ''));
  if (nonEmpty.length < 2) return [];
  const headers = nonEmpty[0].map(s => String(s).trim());
  return nonEmpty.slice(1).map(cells => {
    const row = {};
    headers.forEach((h, i) => { row[h] = (cells[i] !== undefined ? String(cells[i]).trim() : ''); });
    return row;
  });
}

