function addToReserve() {
  const sel = document.getElementById('addToReserve');
  const memberId = sel.value;
  if (!memberId) return;
  const data = loadData();
  if (!data.reserveMemberIds) data.reserveMemberIds = [];
  if (data.reserveMemberIds.includes(memberId)) { alert('이미 예비조에 있습니다'); return; }
  // 다른 조에 있으면 거기서 제거
  removeFromAllTeams(data, memberId);
  data.reserveMemberIds.push(memberId);
  saveData(data);
}

function removeFromReserve(memberId) {
  const data = loadData();
  data.reserveMemberIds = (data.reserveMemberIds || []).filter(id => id !== memberId);
  saveData(data);
}

function setLeader(teamId, memberId) {
  const data = loadData();
  const team = getTeam(data, teamId);
  if (!team) return;
  // 다른 조 조장/부조장이면 거기서 제거
  removeFromAllTeams(data, memberId);
  team.leaderId = memberId;
  saveData(data);
}

function setViceLeader(teamId, memberId) {
  const data = loadData();
  const team = getTeam(data, teamId);
  if (!team) return;
  removeFromAllTeams(data, memberId);
  team.viceLeaderId = memberId;
  saveData(data);
}

function removeFromAllTeams(data, memberId) {
  if (!memberId) return;
  for (const t of (data.teams || [])) {
    if (t.leaderId === memberId) t.leaderId = '';
    if (t.viceLeaderId === memberId) t.viceLeaderId = '';
    t.memberIds = (t.memberIds || []).filter(id => id !== memberId);
  }
}

function addToTeam(teamId) {
  const sel = document.getElementById('addToTeam_' + teamId);
  const memberId = sel.value;
  if (!memberId) return;
  const data = loadData();
  const team = getTeam(data, teamId);
  if (!team) return;
  removeFromAllTeams(data, memberId);
  if (!team.memberIds) team.memberIds = [];
  team.memberIds.push(memberId);
  saveData(data);
}

function removeFromTeam(teamId, memberId) {
  const data = loadData();
  const team = getTeam(data, teamId);
  if (!team) return;
  team.memberIds = (team.memberIds || []).filter(id => id !== memberId);
  team.fixedMemberIds = (team.fixedMemberIds || []).filter(id => id !== memberId);
  saveData(data);
}

function togglePinMember(teamId, memberId) {
  const data = loadData();
  const team = getTeam(data, teamId);
  if (!team) return;
  if (!team.fixedMemberIds) team.fixedMemberIds = [];
  const idx = team.fixedMemberIds.indexOf(memberId);
  if (idx >= 0) team.fixedMemberIds.splice(idx, 1);
  else team.fixedMemberIds.push(memberId);
  saveData(data);
}

function editTeamInfo(teamId) {
  const data = loadData();
  const team = getTeam(data, teamId);
  if (!team) return;
  const name = prompt('조 이름', team.name); if (name === null) return;
  team.name = name.trim();
  saveData(data);
}

function randomAssign() {
  const data = loadData();
  const teams = data.teams || [];
  if (teams.length === 0) { alert('조가 없습니다'); return; }

  // 이미 고정된 회원 ID (조장/부조장/고정조원)
  const fixedIds = new Set();
  for (const t of teams) {
    if (t.leaderId) fixedIds.add(t.leaderId);
    if (t.viceLeaderId) fixedIds.add(t.viceLeaderId);
    for (const id of (t.fixedMemberIds || [])) fixedIds.add(id);
  }

  // 예비조 회원 (랜덤 분배 제외)
  const reserveIds = new Set(data.reserveMemberIds || []);

  // 일반 조원 후보 = 전체 - 고정된 회원 - 예비조
  const candidates = (data.members || [])
    .filter(m => !fixedIds.has(m.id) && !reserveIds.has(m.id))
    .map(m => m.id);

  if (candidates.length === 0) { alert('랜덤 배정할 회원이 없습니다 (전부 고정/예비조)'); return; }

  // 셔플
  for (let i = candidates.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [candidates[i], candidates[j]] = [candidates[j], candidates[i]];
  }

  // 각 조의 memberIds = 고정 + 분배받은 랜덤
  for (const t of teams) {
    t.memberIds = [...(t.fixedMemberIds || [])];
  }
  candidates.forEach((id, idx) => {
    teams[idx % teams.length].memberIds.push(id);
  });

  saveData(data);
  const fixedCount = fixedIds.size - teams.reduce((s, t) => s + (t.leaderId?1:0) + (t.viceLeaderId?1:0), 0);
  alert(`✅ 팀짜기 완료!\n랜덤 분배: ${candidates.length}명\n고정 조원: ${fixedCount}명`);
}

// ────── 저장된 팀 구성 ──────
function saveTeamSnapshot() {
  const data = loadData();
  const teams = data.teams || [];
  if (!teams.length) { alert('저장할 조가 없습니다'); return; }

  const defaultName = new Date().toISOString().slice(0, 10) + ' 구성';
  const name = prompt('이 팀 구성의 이름을 입력하세요\n(예: "5월 1주차", "방역행사용")', defaultName);
  if (!name) return;

  if (!data.savedTeams) data.savedTeams = [];
  data.savedTeams.push({
    id: uid(),
    name: name.trim(),
    savedAt: Date.now(),
    teams: JSON.parse(JSON.stringify(teams)) // 깊은 복사
  });
  saveData(data);
  alert(`✅ "${name}" 저장 완료`);
}

function renderSavedTeams() {
  const data = loadData();
  const saved = (data.savedTeams || []).slice().sort((a, b) => (b.savedAt || 0) - (a.savedAt || 0));
  document.getElementById('savedCount').textContent = `(${saved.length}개)`;
  const el = document.getElementById('savedTeamsList');
  if (!saved.length) {
    el.innerHTML = '<div class="empty">저장된 팀 구성 없음<br><span class="sub">"💾 현재 팀 저장" 버튼으로 백업 가능</span></div>';
    return;
  }

  el.innerHTML = saved.map(s => {
    const when = new Date(s.savedAt).toLocaleString('ko-KR');
    const summary = (s.teams || []).map(t => {
      const total = (t.leaderId?1:0) + (t.viceLeaderId?1:0) + (t.memberIds||[]).length;
      return `${t.name}(${total}명)`;
    }).join(' · ');
    return `
      <div class="list-item" style="flex-direction:column;align-items:stretch;">
        <div class="flex-between">
          <div>
            <b>${s.name}</b>
            <div class="sub">${when} · ${summary}</div>
          </div>
          <div>
            <button class="small" onclick="previewSavedTeam('${s.id}')">미리보기</button>
            <button class="small success" onclick="loadSavedTeam('${s.id}')">불러오기</button>
            <button class="small gray" onclick="renameSavedTeam('${s.id}')">이름</button>
            <button class="small danger" onclick="deleteSavedTeam('${s.id}')">삭제</button>
          </div>
        </div>
      </div>
    `;
  }).join('');
}

function previewSavedTeam(id) {
  const data = loadData();
  const s = (data.savedTeams || []).find(x => x.id === id);
  if (!s) return;
  let msg = `📋 ${s.name}\n${new Date(s.savedAt).toLocaleString('ko-KR')}\n\n`;
  for (const t of (s.teams || [])) {
    const leader = getMember(data, t.leaderId);
    const vice = getMember(data, t.viceLeaderId);
    const members = (t.memberIds || []).map(mid => {
      const m = getMember(data, mid);
      return m ? m.name : '(삭제됨)';
    });
    msg += `[${t.name}] (${t.vehicle || '차량없음'})\n`;
    msg += `  조장: ${leader?.name || '-'}\n`;
    msg += `  부조장: ${vice?.name || '-'}\n`;
    msg += `  조원(${members.length}): ${members.join(', ')}\n\n`;
  }
  alert(msg);
}

function loadSavedTeam(id) {
  const data = loadData();
  const s = (data.savedTeams || []).find(x => x.id === id);
  if (!s) return;
  if (!confirm(`"${s.name}" 구성을 현재 팀에 적용할까요?\n현재 팀 구성은 덮어씌워집니다.`)) return;
  data.teams = JSON.parse(JSON.stringify(s.teams));
  saveData(data);
  alert('✅ 불러오기 완료');
}

function renameSavedTeam(id) {
  const data = loadData();
  const s = (data.savedTeams || []).find(x => x.id === id);
  if (!s) return;
  const name = prompt('이름 변경', s.name);
  if (!name) return;
  s.name = name.trim();
  saveData(data);
}

function deleteSavedTeam(id) {
  if (!confirm('이 저장된 팀 구성을 삭제할까요?')) return;
  const data = loadData();
  data.savedTeams = (data.savedTeams || []).filter(x => x.id !== id);
  saveData(data);
}

function resetTeams() {
  const choice = confirm('조원을 모두 미배정으로 되돌릴까요?\n[확인] = 랜덤 조원만 초기화 (고정·조장·부조장 유지)\n[취소] = 그대로 두기');
  if (!choice) return;
  const data = loadData();
  for (const t of (data.teams || [])) {
    t.memberIds = [...(t.fixedMemberIds || [])];
  }
  saveData(data);
}
</script>
