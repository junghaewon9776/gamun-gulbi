async function resetMemberPin(memberId) {
  const data = loadData();
  const m = getMember(data, memberId);
  if (!m || !m.phone) return;
  if (!confirm(`${m.name}님의 PIN을 ${DEFAULT_PIN}(기본)으로 초기화할까요?`)) return;

  const email = memberEmail(m.phone);
  const newPw = pinToPassword(DEFAULT_PIN);
  const secAuth = getSecondaryAuth();

  // 여러 비번 후보로 로그인 시도 (DB에 저장된 PIN 우선)
  const candidates = [newPw];
  if (m.pin) candidates.push(pinToPassword(m.pin));
  candidates.push(pinToPassword('123456'), pinToPassword('1234'));
  const unique = [...new Set(candidates)];

  let done = false;
  let lastErr = '';
  for (const tryPw of unique) {
    try {
      const cred = await secAuth.signInWithEmailAndPassword(email, tryPw);
      if (tryPw !== newPw) await cred.user.updatePassword(newPw);
      const uid = cred.user.uid;
      await secAuth.signOut();
      // 기본 PIN 플래그 설정
      const fresh = loadData();
      if (fresh.memberPinFlags) { fresh.memberPinFlags[uid] = true; saveData(fresh); }
      done = true;
      break;
    } catch (ex) { lastErr = ex.code || ex.message; }
  }

  if (done) {
    // DB의 pin 필드도 동기화
    m.pin = DEFAULT_PIN;
    saveData(loadData());
    alert(`✅ ${m.name}님 PIN → ${DEFAULT_PIN} 초기화 완료\n\n본인에게 안내해주세요.`);
  } else if (lastErr.includes('user-not-found') || lastErr.includes('invalid-credential')) {
    // Firebase Auth 계정이 없거나 비번 불일치 → 매핑 제거 후 재생성
    // 기존 매핑 제거
    const freshData = loadData();
    const auth = freshData.memberAuth || {};
    for (const [uid, mid] of Object.entries(auth)) {
      if (mid === memberId) {
        delete auth[uid];
        if (freshData.memberPinFlags) delete freshData.memberPinFlags[uid];
      }
    }
    freshData.memberAuth = auth;
    saveData(freshData);

    if (confirm(`${m.name}님 계정을 새로 생성합니다. (PIN: ${DEFAULT_PIN})\n진행할까요?`)) {
      try {
        await createMemberAccount(memberId, m.phone, DEFAULT_PIN);
        alert(`✅ 계정 재생성 완료 (PIN: ${DEFAULT_PIN})`);
        renderMembers();
      } catch (e2) {
        alert(`❌ 계정 생성 실패: ${e2.message}`);
      }
    } else {
      renderMembers(); // 매핑 제거됐으니 UI 갱신
    }
  } else {
    alert(`❌ PIN 초기화 실패\n\n원인: ${lastErr}\n이메일: ${email}\n시도 PIN: ${unique.map(p=>p.replace('bsp','')).join(', ')}`);
  }
}

